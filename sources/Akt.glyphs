code = "lookup ccmp_DFLT_1 {
    @CombiningTopAccents = [acutecomb acutegraveacutecomb acutemacroncomb brevecomb breveinvertedcomb caroncomb circumflexcomb commaabovecomb commareversedabovecomb commaturnedabovecomb dieresiscomb dotaccentcomb doublegravecomb gbridgeabovecomb graveacutegravecomb gravecomb gravemacroncomb hookabovecomb hungarumlautcomb lefthalfringabovecomb macronacutecomb macroncomb macrongravecomb perispomenicomb righthalfringabovecomb ringcomb tildecomb verticallineabovecomb xabovecomb];
    lookupflag UseMarkFilteringSet @CombiningTopAccents;

    sub i' @CombiningTopAccents by idotless;
    sub j' @CombiningTopAccents by jdotless;
    sub j.ss03' @CombiningTopAccents by jdotless.ss03;
    sub istroke' @CombiningTopAccents by istroke.dotless;
    sub i-cy' @CombiningTopAccents by i-cy.dotless;
    sub jcrossedtail' @CombiningTopAccents by jcrossedtail.dotless;
    sub jsuperior' @CombiningTopAccents by jsuperior.dotless;
    sub istrokemod' @CombiningTopAccents by istrokemod.dotless;
    sub imod' @CombiningTopAccents by imod.dotless;
    sub yot' @CombiningTopAccents by yot.dotless;
    sub je-cy' @CombiningTopAccents by je-cy.dotless;

    sub idotbelow' @CombiningTopAccents by idotless dotbelowcomb;
    sub iogonek' @CombiningTopAccents by idotless ogonekcomb;

} ccmp_DFLT_1;

lookup ccmp_DFLT_2 {
	lookupflag 0;
	sub brevecomb acutecomb by brevecomb_acutecomb;
	sub brevecomb gravecomb by brevecomb_gravecomb;
